{
  "name": "native",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "check:page-locks": "node ../scripts/check-page-locks.js --scope=native-ui",
    "check:practitioner-lock": "bash scripts/check-practitioner-native-lock.sh",
    "start": "npm run check:page-locks && npm run check:practitioner-lock && expo start",
    "android": "npm run check:page-locks && npm run check:practitioner-lock && expo run:android",
    "ios": "npm run check:page-locks && npm run check:practitioner-lock && expo run:ios",
    "web": "npm run check:page-locks && npm run check:practitioner-lock && expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-health": "^1.19.0",
    "react-native-iap": "^14.7.12",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
