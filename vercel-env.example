# Vercel Environment Configuration for Helfi.ai
# Copy these to your .env.local file in Vercel dashboard

# Authentication
NEXTAUTH_SECRET=helfi-secret-key-production-2024
NEXTAUTH_URL=https://helfi.ai

# Vercel Postgres Database
# Get this from your Vercel dashboard > Storage > Postgres
POSTGRES_URL="postgres://default:YOUR_PASSWORD@YOUR_VERCEL_POSTGRES.vercel-storage.com:5432/verceldb"
DATABASE_URL="postgres://default:YOUR_PASSWORD@YOUR_VERCEL_POSTGRES.vercel-storage.com:5432/verceldb"

# Email Provider for authentication (NextAuth)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=noreply@helfi.ai
EMAIL_SERVER_PASSWORD=YOUR_EMAIL_PASSWORD
EMAIL_FROM=noreply@helfi.ai

# Google OAuth for authentication (optional)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Disable any Supabase references completely
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY="" 